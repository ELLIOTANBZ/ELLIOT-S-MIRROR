FLASK_SECRET_KEY=change-this-local-secret
MIRROR_DEBUG=true
# On COMET, set MIRROR_LOCAL_ROOT to your private OneDrive folder, for example:
# C:/Users/cpfaceta/OneDrive - SG Govt M365/MIRROR
MIRROR_LOCAL_ROOT=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR
MIRROR_DB_PATH=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/database/master.db
MIRROR_MASTER_DB_PATH=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/database/master.db

# Local-only workflow folders. SharePoint is manual download/upload only.
MIRROR_INCOMING_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/incoming
MIRROR_DATABASE_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/database
MIRROR_OUTGOING_CHANGES_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/outgoing_changes
MIRROR_PROCESSED_CHANGES_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/processed_changes
MIRROR_FAILED_CHANGES_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/failed_changes
MIRROR_PROCESSED_IMPORTS_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/processed_imports
MIRROR_FAILED_IMPORTS_DIR=C:/Users/YOUR_USERNAME/OneDrive - SG Govt M365/MIRROR/failed_imports

# The watchdog waits until a downloaded file stops changing before importing it.
WATCH_STABLE_SECONDS=10
# Optional fallback when filenames do not start with username__
WATCH_DEFAULT_OFFICER_ID=

# Approved GenAI provider. Recommended: azure_openai
# Supported planned values: azure_openai, openai, claude
AI_PROVIDER=azure_openai

# Fill these only if AI_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Fill these only if AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=

# Fill these only if AI_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
